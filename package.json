{
  "name": "teamshare",
  "displayName": "TeamShare - Claude Code Session Intelligence",
  "description": "Multi-user session intelligence for Claude Code. Track who's doing what, search across sessions, prevent conflicts.",
  "version": "0.1.0",
  "publisher": "NorwayIsHere",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/norwayiscoming/vs-code-extension-template"
  },
  "homepage": "https://github.com/norwayiscoming/vs-code-extension-template#readme",
  "bugs": {
    "url": "https://github.com/norwayiscoming/vs-code-extension-template/issues"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "collaboration",
    "team",
    "session",
    "multi-agent",
    "anthropic"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "myExtension.helloWorld",
        "title": "Hello World",
        "category": "TeamShare"
      },
      {
        "command": "myExtension.showPanel",
        "title": "Show Panel",
        "category": "TeamShare"
      },
      {
        "command": "myExtension.sessions.search",
        "title": "Search Sessions",
        "category": "TeamShare",
        "icon": "$(search)"
      },
      {
        "command": "myExtension.sessions.refresh",
        "title": "Refresh Sessions",
        "category": "TeamShare",
        "icon": "$(refresh)"
      },
      {
        "command": "myExtension.sessions.reindex",
        "title": "Rebuild Search Index",
        "category": "TeamShare"
      },
      {
        "command": "myExtension.sessions.identify",
        "title": "Set User Identity",
        "category": "TeamShare"
      },
      {
        "command": "myExtension.sessions.indexFile",
        "title": "Index Session File",
        "category": "TeamShare"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "myExtensionSidebar",
          "title": "TeamShare",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "myExtensionSidebar": [
        {
          "id": "myExtension.treeView",
          "name": "Explorer",
          "type": "tree"
        },
        {
          "id": "myExtension.webviewView",
          "name": "Details",
          "type": "webview"
        },
        {
          "id": "myExtension.sessionTree",
          "name": "Sessions",
          "type": "tree"
        }
      ]
    },
    "configuration": {
      "title": "TeamShare",
      "properties": {
        "myExtension.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the extension features"
        },
        "myExtension.logLevel": {
          "type": "string",
          "default": "info",
          "enum": ["debug", "info", "warn", "error"],
          "description": "Set the logging level"
        },
        "teamshare.sessionIntelligence.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable session intelligence module"
        },
        "teamshare.sessionIntelligence.embedding.provider": {
          "type": "string",
          "default": "none",
          "enum": ["none", "openai", "ollama", "voyage"],
          "description": "Embedding provider for semantic search (optional)"
        },
        "teamshare.sessionIntelligence.embedding.model": {
          "type": "string",
          "default": "text-embedding-3-small",
          "description": "Embedding model name"
        },
        "teamshare.sessionIntelligence.embedding.dimensions": {
          "type": "number",
          "default": 256,
          "description": "Embedding vector dimensions"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "myExtension.helloWorld",
          "when": "view == myExtension.treeView",
          "group": "navigation"
        },
        {
          "command": "myExtension.sessions.search",
          "when": "view == myExtension.sessionTree",
          "group": "navigation"
        },
        {
          "command": "myExtension.sessions.refresh",
          "when": "view == myExtension.sessionTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vscode-test",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@stylistic/eslint-plugin": "^2.9.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.13.0",
    "mocha": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  },
  "dependencies": {}
}
