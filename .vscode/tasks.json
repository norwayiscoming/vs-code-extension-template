{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": [
        {
          "base": "$tsc-watch",
          "applyTo": "allDocuments"
        },
        {
          "base": "$esbuild-watch",
          "applyTo": "allDocuments"
        }
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "npm: watch"
    },
    {
      "type": "npm",
      "script": "compile",
      "group": "build",
      "label": "npm: compile"
    },
    {
      "type": "npm",
      "script": "pretest",
      "group": "build",
      "label": "npm: pretest"
    }
  ]
}
